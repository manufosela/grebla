---
import Base from '../layouts/Base.astro';

/**
 * Landing del framework de gestión. Punto de entrada que lista las herramientas
 * disponibles. Por ahora solo Role Mirror; aquí se irán añadiendo más.
 */
const tools = [
  {
    name: 'Role Mirror',
    href: '/tools/role-mirror',
    description: 'Autodiagnóstico de perfil de ingeniería: cuestionario adaptativo y mapa de competencias.',
    available: true,
  },
  {
    name: 'Equipo',
    href: '/tools/team',
    description: 'Seguimiento de equipo en 4 dimensiones, cobertura de roles, bus factor y conversaciones 1:1.',
    available: true,
  },
  {
    name: 'DORA',
    href: '/tools/dora',
    description: 'Métricas de entrega a nivel de equipo (lead time, deploy frequency…) desde los repos de la organización.',
    available: true,
  },
  {
    name: 'Flujo (LEAN)',
    href: '/tools/lean',
    description: 'Métricas de flujo del equipo desde Linear: throughput, cycle time (p50/p85), WIP y aging. Complementan a DORA.',
    available: true,
  },
  {
    name: 'Mapa de Carrera',
    href: '/tools/career-map',
    description: 'Traza tu ruta de crecimiento en una isla de casas (skills, tecnologías, hitos), gamificado.',
    available: true,
  },
  {
    name: 'O2O',
    href: '/tools/o2o',
    description: 'Gestión de One-to-Ones: guía de temas, formulario previo y (próximamente) registro con IA, acciones y evolución.',
    available: true,
  },
  {
    name: 'Moving Motivators',
    href: '/tools/motivators/moving',
    description: 'Juego de cartas: ordena qué te mueve en el trabajo (curiosidad, maestría, propósito…). Reflexión personal y resultados de equipo por rondas.',
    available: true,
  },
  {
    name: 'Affective Motivators',
    href: '/tools/motivators/affective',
    description: 'Juego de cartas: ordena qué necesitas sentir en tu equipo (escucha, confianza, pertenencia…). Reflexión personal y resultados de equipo por rondas.',
    available: true,
  },
  {
    name: 'Marea',
    href: '/marea',
    description: 'El pulso afectivo de la semana: cómo navegas (energía y ánimo) y cuatro anclas. Un registro al día; resultados del equipo siempre agregados y anónimos.',
    available: true,
  },
];
---

<Base title="GREBLA">
  <section class="hero">
    <h1 class="page-title">GREBLA</h1>
    <p class="page-tagline">Gestión Reflexiva de Equipos Bajo un Liderazgo Afectivo</p>
    <p class="page-lead">
      Herramientas para entender y desarrollar a tus equipos y a las personas
      que los forman.
    </p>
  </section>

  <!-- Sin sesión/acceso: visible por defecto. landing.js la oculta al entrar. -->
  <section id="platform-landing" class="landing">
    <p class="page-lead">Inicia sesión arriba a la derecha para acceder a las herramientas.</p>
    <p class="muted">
      Si no tienes acceso, pide a un superadmin de la organización que te dé de alta como líder.
    </p>
  </section>

  <!-- Volver a gestión: solo para superadmin que usa la vista de líder. -->
  <div id="back-to-admin" class="back-admin" hidden>
    <button type="button">← Volver a gestión (superadmin)</button>
  </div>

  <!-- Herramientas: ocultas por defecto. landing.js las muestra con sesión y acceso. -->
  <section id="tenant-tools" class="tools" hidden>
    {
      tools.map((tool) => (
        <a class="tool-card" href={tool.href} aria-disabled={!tool.available}>
          <h2>{tool.name}</h2>
          <p>{tool.description}</p>
          <span class="cta">Abrir →</span>
        </a>
      ))
    }
    <div class="tool-card placeholder" aria-hidden="true">
      <h2>Más herramientas</h2>
      <p>Próximamente. Aquí se añadirán nuevos módulos del framework.</p>
    </div>
  </section>

  <script>
    import '../client/landing.js';
  </script>
</Base>

<style>
  .hero { margin-bottom: 2rem; }
  .page-tagline {
    margin: 0 0 0.75rem;
    color: var(--gr-teal);
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .tools {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--rm-surface);
    border: 1px solid var(--rm-border);
    border-radius: var(--rm-radius);
    padding: 1.25rem 1.4rem;
    text-decoration: none;
    color: var(--rm-text);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .tool-card:hover { border-color: var(--rm-accent); transform: translateY(-2px); }
  .tool-card h2 { margin: 0; font-size: 1.15rem; }
  .tool-card p { margin: 0; color: var(--rm-muted); font-size: 0.9rem; }
  .tool-card .cta { margin-top: auto; color: var(--rm-accent); font-weight: 700; font-size: 0.9rem; }
  .tool-card.placeholder { opacity: 0.6; border-style: dashed; cursor: default; }
  .tool-card.placeholder:hover { border-color: var(--rm-border); transform: none; }

  .back-admin { margin-bottom: 1rem; }
  .back-admin button {
    border: 1px solid var(--rm-border); background: var(--rm-surface); color: var(--rm-accent);
    border-radius: 999px; padding: 0.4rem 1rem; font-size: 0.85rem; font-weight: 600; cursor: pointer;
  }
  .back-admin button:hover { border-color: var(--rm-accent); }
</style>
