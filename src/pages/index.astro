---
import Base from '../layouts/Base.astro';

/**
 * Landing del framework de gestión. Punto de entrada que lista las herramientas
 * disponibles. Por ahora solo Role Mirror; aquí se irán añadiendo más.
 */
const tools = [
  {
    name: 'Role Mirror',
    href: '/tools/role-mirror',
    description: 'Autodiagnóstico de perfil de ingeniería: cuestionario adaptativo y mapa de competencias.',
    available: true,
  },
  {
    name: 'Equipo',
    href: '/tools/team',
    description: 'Seguimiento de equipo en 4 dimensiones, cobertura de roles, bus factor y conversaciones 1:1.',
    available: true,
  },
  {
    name: 'DORA',
    href: '/tools/dora',
    description: 'Métricas de entrega a nivel de equipo (lead time, deploy frequency…) desde los repos de la organización.',
    available: true,
  },
  {
    name: 'Mapa de Carrera',
    href: '/tools/career-map',
    description: 'Traza tu ruta de crecimiento en un mapa de ciudades (skills, tecnologías, hitos), gamificado.',
    available: true,
  },
];
---

<Base title="GREBLA">
  <section class="hero">
    <h1 class="page-title">GREBLA</h1>
    <p class="page-tagline">Gestión Reflexiva de Equipos Bajo un Liderazgo Afectivo</p>
    <p class="page-lead">
      Herramientas para entender y desarrollar a tus equipos y a las personas
      que los forman.
    </p>
  </section>

  <!-- Plataforma (sin tenant): visible por defecto. landing.js la oculta dentro de /{tenant}. -->
  <section id="platform-landing" class="landing">
    <p class="page-lead">
      Las herramientas viven dentro de tu organización:
      <code>grebla.app/tu-organización</code>.
    </p>
    <p class="muted">
      Inicia sesión arriba a la derecha para entrar. Si no conoces el identificador
      de tu organización, pídeselo a un administrador.
    </p>
  </section>

  <!-- Tenant: oculto por defecto. landing.js lo muestra cuando hay /{tenant} en la URL;
       layout.js prefija los enlaces de las tarjetas con /{tenant}. -->
  <section id="tenant-tools" class="tools" hidden>
    {
      tools.map((tool) => (
        <a class="tool-card" href={tool.href} aria-disabled={!tool.available}>
          <h2>{tool.name}</h2>
          <p>{tool.description}</p>
          <span class="cta">Abrir →</span>
        </a>
      ))
    }
    <div class="tool-card placeholder" aria-hidden="true">
      <h2>Más herramientas</h2>
      <p>Próximamente. Aquí se añadirán nuevos módulos del framework.</p>
    </div>
  </section>

  <script>
    import '../client/landing.js';
  </script>
</Base>

<style>
  .hero { margin-bottom: 2rem; }
  .page-tagline {
    margin: 0 0 0.75rem;
    color: var(--gr-teal);
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .tools {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .tool-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--rm-surface);
    border: 1px solid var(--rm-border);
    border-radius: var(--rm-radius);
    padding: 1.25rem 1.4rem;
    text-decoration: none;
    color: var(--rm-text);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .tool-card:hover { border-color: var(--rm-accent); transform: translateY(-2px); }
  .tool-card h2 { margin: 0; font-size: 1.15rem; }
  .tool-card p { margin: 0; color: var(--rm-muted); font-size: 0.9rem; }
  .tool-card .cta { margin-top: auto; color: var(--rm-accent); font-weight: 700; font-size: 0.9rem; }
  .tool-card.placeholder { opacity: 0.6; border-style: dashed; cursor: default; }
  .tool-card.placeholder:hover { border-color: var(--rm-border); transform: none; }
</style>
