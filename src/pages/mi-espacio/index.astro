---
import Base from '../../layouts/Base.astro';

/**
 * «Mi espacio»: página personal del ingeniero (persona con cuenta vinculada).
 * Layout neutro (Base), SIN la navegación de herramientas de manager. La cabecera
 * de identidad y el guard de acceso los pinta/aplica el glue de cliente
 * (client/engineer.js). El contenido de las tres secciones (Carrera, Role Mirror
 * y Mapa de carrera) lo pinta el componente <engineer-space>, que el glue rellena
 * con los datos de la persona en SOLO LECTURA (G3, RMR-TSK-0095).
 */
---

<Base title="GREBLA — Mi espacio">
  <section class="me-header">
    <h1 class="page-title">Mi espacio</h1>

    <!-- Cabecera de identidad: la rellena engineer.js en solo lectura. -->
    <div id="engineer-identity" class="identity" hidden>
      <div class="identity-row">
        <div>
          <p class="identity-name" data-name></p>
          <p class="identity-title" data-title hidden></p>
        </div>
        <!-- El ingeniero abre SU mapa (JG-1, RMR-TSK-0139): acceso destacado con
             su propia cuenta; el plan que consulta/edita allí es el suyo. Entra a
             la vista Lista por defecto (RMR-TSK-0205), no al juego. -->
        <a class="play-cta" href="/tools/career-map">📋 Mi ruta de carrera</a>
      </div>
    </div>

    <!-- Mensaje de error sobrio si algo falla al cargar. -->
    <p id="engineer-error" class="me-error" role="alert" hidden></p>
  </section>

  <!-- Skeleton con la FORMA FINAL (cabecera + pestañas + contenido): reserva el
       hueco desde el primer pintado para que no haya salto de layout (CLS,
       RMR-TSK-0263). engineer.js lo quita y revela el contenido de una vez. -->
  <div id="me-skeleton" class="me-skeleton" aria-hidden="true">
    <div class="sk-identity">
      <app-skeleton w="190px" h="1.2rem"></app-skeleton>
      <app-skeleton w="260px" h="0.9rem"></app-skeleton>
    </div>
    <div class="sk-tabs">
      <app-skeleton w="88px" h="2.1rem" radius="999px"></app-skeleton>
      <app-skeleton w="104px" h="2.1rem" radius="999px"></app-skeleton>
      <app-skeleton w="120px" h="2.1rem" radius="999px"></app-skeleton>
      <app-skeleton w="96px" h="2.1rem" radius="999px"></app-skeleton>
    </div>
    <app-skeleton h="320px"></app-skeleton>
  </div>

  <!-- Contenido de las secciones (lo rellena engineer.js). Arranca oculto y se
       revela junto con la cabecera cuando los datos están listos. Los motivadores
       viven como pestaña dentro de <engineer-space> (RMR-TSK-0260). -->
  <engineer-space hidden></engineer-space>

  <script>
    import '../../components/app-skeleton.js';
    import '../../client/engineer.js';
  </script>
</Base>

<style>
  .me-header { margin-bottom: 2rem; }
  .identity {
    margin-top: 0.5rem;
    padding: 1rem 1.25rem;
    background: var(--rm-surface);
    border: 1px solid var(--rm-border);
    border-radius: var(--rm-radius);
  }
  .identity-name { margin: 0; font-size: 1.15rem; font-weight: 700; color: var(--rm-text); }
  .identity-title { margin: 0.25rem 0 0; color: var(--rm-accent); font-weight: 600; }
  .identity-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .play-cta {
    display: inline-block;
    padding: 0.55rem 1.1rem;
    background: var(--rm-accent);
    color: var(--rm-on-accent, #fff);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
  }
  .play-cta:hover { filter: brightness(1.08); }
  .play-cta:focus-visible { outline: 2px solid var(--rm-accent); outline-offset: 2px; }
  .me-error { color: var(--rm-danger); font-size: 0.9rem; margin: 0.75rem 0 0; }
  /* Skeleton de carga (RMR-TSK-0263): misma forma que el contenido final. */
  .me-skeleton { display: flex; flex-direction: column; gap: 1.25rem; }
  .me-skeleton .sk-identity {
    display: flex; flex-direction: column; gap: 0.55rem;
    padding: 1rem 1.25rem; background: var(--rm-surface); border: 1px solid var(--rm-border);
    border-radius: var(--rm-radius);
  }
  .me-skeleton .sk-tabs { display: flex; gap: 0.5rem; flex-wrap: wrap; }
</style>
