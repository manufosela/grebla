---
import Career from '../../../layouts/Career.astro';
---

<Career title="GREBLA — Mapa de Carrera">
  <!-- El protagonista es el mapa: el título queda en la barra compacta del
       layout (◇ Mapa de Carrera) y aquí solo se conserva un h1 accesible. -->
  <h1 class="sr-only">Mapa de carrera</h1>
  <career-app></career-app>
</Career>

<script>
  import '../../../client/career.js';
</script>

<style is:global>
  /* Página a viewport completo: el canvas de la isla ocupa toda la altura
     disponible bajo la cabecera. Estas reglas son globales SOLO en esta página
     (cada página estática de Astro es su propio documento) y el interior de
     <career-app> es Shadow DOM, así que no interfieren con otros componentes. */
  html,
  body {
    height: 100%;
  }
  body {
    display: flex;
    flex-direction: column;
  }
  .site-main {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    max-width: none;
    width: 100%;
    padding: 0 1rem 0.75rem;
  }
  /* Sin pie en esta página: cada píxel vertical es para el mapa. */
  .site-footer {
    display: none;
  }
  career-app {
    flex: 1 1 auto;
    min-height: 0;
  }
  /* Título accesible pero invisible (el nombre visible va en la tool-nav). */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
    border: 0;
  }
</style>
