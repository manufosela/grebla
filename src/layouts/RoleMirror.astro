---
/**
 * Layout de la herramienta Role Mirror. Envuelve el layout global Base y añade
 * la sub-navegación propia de la herramienta (Cuestionario / Admin). Cada
 * herramienta del framework puede tener su propio layout de este estilo.
 *
 * Props:
 *  - title: string
 *  - requireAuth?: boolean
 *  - requireAdmin?: boolean
 */
import Base from './Base.astro';

const { title = 'Role Mirror', requireAuth = false, requireAdmin = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, '');
const isAdmin = path.startsWith('/tools/role-mirror/admin');
const isQuestionnaire = path === '/tools/role-mirror';
---

<Base title={title} requireAuth={requireAuth} requireAdmin={requireAdmin}>
  <nav class="tool-nav" aria-label="Role Mirror">
    <span class="tool-name">◑ Role Mirror</span>
    <a href="/tools/role-mirror" class:list={["tool-link", { active: isQuestionnaire }]}>Cuestionario</a>
    <a href="/tools/role-mirror/admin" class:list={["tool-link", { active: isAdmin }]}>Admin</a>
  </nav>
  <slot />
</Base>

<style>
  .tool-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rm-border);
  }
  .tool-name { font-weight: 800; color: var(--rm-accent); }
  .tool-link {
    text-decoration: none;
    color: var(--rm-muted);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .tool-link:hover { color: var(--rm-text); }
  .tool-link.active { color: var(--rm-text); border-bottom: 2px solid var(--rm-accent); padding-bottom: 0.2rem; }
</style>
