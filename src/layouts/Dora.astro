---
/**
 * Layout de la herramienta DORA. Envuelve Base y marca la ruta como protegida.
 * Props: title
 */
import Base from './Base.astro';

const { title = 'DORA' } = Astro.props;
---

<Base title={title} requireAuth={true}>
  <nav class="tool-nav" aria-label="DORA">
    <a href="/" class="tool-back">← Volver</a>
    <span class="tool-name">▲ DORA</span>
  </nav>
  <slot />
</Base>

<style>
  .tool-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rm-border);
  }
  .tool-name { font-weight: 800; color: var(--rm-accent); }
</style>
