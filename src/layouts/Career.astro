---
/**
 * Layout del Mapa de Carrera. Envuelve Base y marca la ruta como protegida.
 * Props: title
 */
import Base from './Base.astro';

const { title = 'Mapa de Carrera' } = Astro.props;
---

<Base title={title} requireAuth={true}>
  <nav class="tool-nav" aria-label="Mapa de Carrera">
    <a href="/" class="tool-back">← Volver</a>
    <span class="tool-name">◇ Mapa de Carrera</span>
  </nav>
  <slot />
</Base>

<style>
  .tool-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--rm-border);
  }
  .tool-name { font-weight: 800; color: var(--rm-accent); }
  /* En móvil cada píxel vertical es para el juego: barra mínima. */
  @media (max-width: 760px) {
    .tool-nav {
      margin-bottom: 0.4rem;
      padding-bottom: 0.35rem;
    }
  }
</style>
