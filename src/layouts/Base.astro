---
/**
 * Layout base. Declara las CSS custom properties en :root (consumidas por los
 * componentes Lit con var(--rm-*)) y un guard de auth client-side opcional.
 *
 * Props:
 *  - title: string
 *  - requireAuth?: boolean   redirige a /login si no hay sesión
 *  - requireAdmin?: boolean  redirige a / si hay sesión pero no es admin
 */
const { title = 'GREBLA', requireAuth = false, requireAdmin = false } = Astro.props;

const ogDescription =
  'GREBLA — Guía de Referencia de Equipos Bajo Liderazgo Afectivo. Herramientas para entender y desarrollar equipos y personas.';
// Si se configura `site` en astro.config.mjs, la imagen social usará URL absoluta.
const ogImage = Astro.site ? new URL('/og-image.png', Astro.site).href : '/og-image.png';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={ogDescription} />
    <title>{title}</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1e3a5f" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GREBLA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body data-require-auth={String(requireAuth)} data-require-admin={String(requireAdmin)}>
    <header class="site-header">
      <a class="brand" href="/">
        <svg class="brand-mark" viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="32" r="25" fill="none" stroke="var(--gr-navy)" stroke-opacity="0.35" stroke-width="3" />
          <circle cx="7" cy="32" r="4" fill="var(--gr-teal)" />
          <circle cx="57" cy="32" r="4" fill="var(--gr-teal)" />
          <polygon points="32,6 26,31 38,31" fill="var(--gr-teal)" />
          <polygon points="32,58 26,33 38,33" fill="var(--gr-navy)" />
          <path d="M32 38 C 27 33 23 31 23 27.2 C 23 24.6 25 23 27.5 23 C 29.6 23 31 24.6 32 26.2 C 33 24.6 34.4 23 36.5 23 C 39 23 41 24.6 41 27.2 C 41 31 37 33 32 38 Z" fill="var(--gr-coral)" />
        </svg>
        <span class="brand-word">GREBLA</span>
      </a>
      <nav class="site-nav">
        <a href="/">Inicio</a>
        <a href="/tools/role-mirror">Role Mirror</a>
        <!-- Web component definido e hidratado desde el <script> de cliente de
             abajo. No usamos client:only para no importar firebase en el build. -->
        <auth-button></auth-button>
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>GREBLA · Guía de Referencia de Equipos Bajo Liderazgo Afectivo</p>
    </footer>

    <style is:global>
      :root {
        /* Paleta GREBLA (extraída del logo) */
        --gr-navy: #1e3a5f;       /* azul marino: marca, texto */
        --gr-navy-700: #16304f;
        --gr-teal: #2a9d8f;       /* teal: acento interactivo */
        --gr-teal-600: #23867a;
        --gr-teal-soft: #e6f4f1;
        --gr-coral: #f2887a;      /* coral: acento afectivo (el corazón) */
        --gr-coral-600: #e26d5e;
        --gr-coral-soft: #fdecea;

        --rm-font: 'Segoe UI', system-ui, -apple-system, Roboto, 'Helvetica Neue', sans-serif;
        --rm-bg: #f6f9fa;
        --rm-surface: #ffffff;
        --rm-surface-hover: #eef3f5;
        --rm-text: var(--gr-navy);
        --rm-muted: #5b6b7d;
        --rm-border: #dde7ec;
        --rm-track: #e9f0f2;
        --rm-accent: var(--gr-teal);
        --rm-brand: var(--gr-navy);
        --rm-warning: var(--gr-coral);
        --rm-danger: #dc2626;
        --rm-success: #16a34a;
        --rm-radius: 14px;
        --rm-max: 1100px;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--rm-bg);
        color: var(--rm-text);
        font-family: var(--rm-font);
        line-height: 1.5;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        max-width: var(--rm-max);
        margin: 0 auto;
        padding: 1rem 1.5rem;
        flex-wrap: wrap;
      }
      .brand {
        font-weight: 700;
        font-size: 1.2rem;
        text-decoration: none;
        color: var(--gr-navy);
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
      }
      .brand-word { letter-spacing: 0.14em; }
      .brand-mark { width: 30px; height: 30px; display: block; }
      .site-nav { display: flex; align-items: center; gap: 1.25rem; }
      .site-nav a {
        text-decoration: none;
        color: var(--rm-muted);
        font-weight: 600;
        font-size: 0.9rem;
      }
      .site-nav a:hover { color: var(--rm-text); }

      .site-main {
        max-width: var(--rm-max);
        margin: 0 auto;
        padding: 1rem 1.5rem 3rem;
      }
      .site-footer {
        max-width: var(--rm-max);
        margin: 0 auto;
        padding: 1.5rem;
        color: var(--rm-muted);
        font-size: 0.8rem;
        border-top: 1px solid var(--rm-border);
      }
      h1.page-title { font-size: 1.6rem; margin: 0.5rem 0 0.25rem; }
      p.page-lead { color: var(--rm-muted); margin: 0 0 1.5rem; max-width: 60ch; }
    </style>

    <!-- Define <auth-button> y aplica el guard de rutas protegidas. -->
    <script>
      import '../client/layout.js';
    </script>
  </body>
</html>
