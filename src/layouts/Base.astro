---
/**
 * Layout base. Declara las CSS custom properties en :root (consumidas por los
 * componentes Lit con var(--rm-*)) y un guard de auth client-side opcional.
 *
 * Props:
 *  - title: string
 *  - requireAuth?: boolean   redirige a /login si no hay sesión
 *  - requireAdmin?: boolean  redirige a / si hay sesión pero no es admin
 */
import pkg from '../../package.json';

const { title = 'GREBLA', requireAuth = false, requireAdmin = false } = Astro.props;
// Versión semántica incrustada al compilar (para bumpear: cambia package.json).
// Estática en el HTML: si el pie muestra una versión vieja, estás cacheado.
const appVersion = pkg.version;

const ogDescription =
  'GREBLA — Gestión Reflexiva de Equipos Bajo un Liderazgo Afectivo. Herramientas para entender y desarrollar equipos y personas.';
// Si se configura `site` en astro.config.mjs, la imagen social usará URL absoluta.
const ogImage = Astro.site ? new URL('/og-image.png', Astro.site).href : '/og-image.png';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={ogDescription} />
    <title>{title}</title>

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1e3a5f" />
    <meta name="color-scheme" content="light dark" />

    <!-- Anti-FOUC: aplica el tema guardado (o el del sistema) ANTES del primer
         paint. Va inline para no depender del bundle de cliente. -->
    <script is:inline>
      (() => {
        let stored = null;
        try {
          stored = localStorage.getItem('grebla-theme');
        } catch {
          /* localStorage puede no estar disponible (modo privado estricto) */
        }
        const dark = stored ? stored === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        if (dark) {
          document.querySelector('meta[name="theme-color"]')?.setAttribute('content', '#12161d');
        }
      })();
    </script>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="GREBLA" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body data-require-auth={String(requireAuth)} data-require-admin={String(requireAdmin)}>
    <header class="site-header">
      <a class="brand" href="/">
        <svg class="brand-mark" viewBox="0 0 64 64" aria-hidden="true">
          <circle cx="32" cy="32" r="25" fill="none" stroke="var(--gr-navy)" stroke-opacity="0.35" stroke-width="3" />
          <circle cx="7" cy="32" r="4" fill="var(--gr-teal)" />
          <circle cx="57" cy="32" r="4" fill="var(--gr-teal)" />
          <polygon points="32,6 26,31 38,31" fill="var(--gr-teal)" />
          <polygon points="32,58 26,33 38,33" fill="var(--gr-navy)" />
          <path d="M32 38 C 27 33 23 31 23 27.2 C 23 24.6 25 23 27.5 23 C 29.6 23 31 24.6 32 26.2 C 33 24.6 34.4 23 36.5 23 C 39 23 41 24.6 41 27.2 C 41 31 37 33 32 38 Z" fill="var(--gr-coral)" />
        </svg>
        <span class="brand-word">GREBLA</span>
      </a>
      <nav class="site-nav">
        <a href="/">Inicio</a>
        <a href="/guia">Guía</a>
        <a href="/glosario">Glosario</a>
        <!-- Conmutador de tema claro/oscuro. La lógica vive en client/layout.js
             y el estado (aria-pressed, icono) se deriva de html[data-theme]. -->
        <button
          type="button"
          class="theme-toggle"
          id="theme-toggle"
          aria-label="Cambiar entre tema claro y oscuro"
          aria-pressed="false"
        >
          <span class="icon-sun" aria-hidden="true">☀️</span>
          <span class="icon-moon" aria-hidden="true">🌙</span>
        </button>
        <!-- Web component definido e hidratado desde el <script> de cliente de
             abajo. No usamos client:only para no importar firebase en el build. -->
        <auth-button></auth-button>
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <p>GREBLA · Gestión Reflexiva de Equipos Bajo un Liderazgo Afectivo · versión {appVersion}</p>
    </footer>

    <style is:global>
      :root {
        /* Paleta GREBLA (extraída del logo) */
        --gr-navy: #1e3a5f;       /* azul marino: marca, texto */
        --gr-navy-700: #16304f;
        --gr-teal: #2a9d8f;       /* teal: acento interactivo */
        --gr-teal-600: #23867a;
        --gr-teal-soft: #e6f4f1;
        --gr-coral: #f2887a;      /* coral: acento afectivo (el corazón) */
        --gr-coral-600: #e26d5e;
        --gr-coral-soft: #fdecea;

        --rm-font: 'Segoe UI', system-ui, -apple-system, Roboto, 'Helvetica Neue', sans-serif;
        --rm-bg: #f6f9fa;
        --rm-surface: #ffffff;
        --rm-surface-hover: #eef3f5;
        --rm-text: var(--gr-navy);
        --rm-muted: #5b6b7d;
        --rm-border: #dde7ec;
        --rm-track: #e9f0f2;
        --rm-accent: var(--gr-teal);
        --rm-brand: var(--gr-navy);
        --rm-warning: var(--gr-coral);
        --rm-danger: #dc2626;
        --rm-success: #16a34a;
        --rm-radius: 14px;
        --rm-max: 1100px;

        color-scheme: light;
      }

      /* Tema oscuro (RMR-TSK-0151). Redefine los tokens semánticos --rm-* y la
         paleta --gr-* derivándolos de la marca: mismos matices, luminosidad
         ajustada para contraste AA sobre fondo oscuro. El juego del Mapa de
         Carrera NO cambia: su overlay pergamino re-declara los --rm-* dentro
         de su Shadow DOM. Los tokens que los componentes consumen solo vía
         fallback (--rm-navy, --rm-coral…, --rm-on-accent…) se definen SOLO
         aquí: en claro sigue aplicando el fallback y nada cambia. */
      html[data-theme='dark'] {
        color-scheme: dark;

        /* Paleta GREBLA sobre oscuro */
        --gr-navy: #aec6e8;
        --gr-navy-700: #c4d6ef;
        --gr-teal: #45c8b6;
        --gr-teal-600: #5fd3c3;
        --gr-teal-soft: #17302c;
        --gr-coral: #f2887a;
        --gr-coral-600: #e8796b;
        --gr-coral-soft: #3b211d;

        /* Tokens semánticos */
        --rm-bg: #12161d;
        --rm-surface: #1a202a;
        --rm-surface-hover: #232b38;
        --rm-text: #e8eaf0;
        --rm-muted: #9fadbf;
        --rm-border: #2b3442;
        --rm-track: #222a36;
        --rm-danger: #f47c74;
        --rm-success: #57c877;

        /* Tokens consumidos vía fallback en los componentes */
        --rm-navy: var(--gr-navy);
        --rm-coral: var(--gr-coral);
        --rm-coral-600: var(--gr-coral-600);
        --rm-coral-soft: var(--gr-coral-soft);
        --rm-teal-600: var(--gr-teal-600);
        --rm-teal-soft: var(--gr-teal-soft);
        --rm-accent-soft: var(--gr-teal-soft);
        --rm-accent-700: #7adccd;

        /* Sobre acento brillante el texto va en tinta oscura (AA) */
        --rm-on-accent: #10141a;
        --rm-overlay: rgba(0, 0, 0, 0.65);
        --rm-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        --rm-dot-border: rgba(255, 255, 255, 0.2);

        /* Píldoras de estado (fondo tintado + texto claro) */
        --rm-success-soft: #15321f;
        --rm-success-strong: #7ee2a0;
        --rm-danger-soft: #3a1e1e;
        --rm-danger-strong: #f9968f;
        --rm-warning-soft: #382912;
        --rm-warning-strong: #f0b263;
      }

      * { box-sizing: border-box; }

      /* El atributo `hidden` debe ocultar SIEMPRE, también en elementos con un
         display propio (p. ej. .tools usa display:grid, que de otro modo gana a
         la regla del navegador para [hidden]). */
      [hidden] { display: none !important; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--rm-bg);
        color: var(--rm-text);
        font-family: var(--rm-font);
        line-height: 1.5;
      }

      .site-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        max-width: var(--rm-max);
        margin: 0 auto;
        padding: 1rem 1.5rem;
        flex-wrap: wrap;
      }
      .brand {
        font-weight: 700;
        font-size: 1.2rem;
        text-decoration: none;
        color: var(--gr-navy);
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
      }
      .brand-word { letter-spacing: 0.14em; }
      .brand-mark { width: 30px; height: 30px; display: block; }
      .site-nav { display: flex; align-items: center; gap: 1.25rem; }
      .site-nav a {
        text-decoration: none;
        color: var(--rm-muted);
        font-weight: 600;
        font-size: 0.9rem;
      }
      .site-nav a:hover { color: var(--rm-text); }

      /* Conmutador de tema: muestra el icono del tema al que se va a cambiar. */
      .theme-toggle {
        display: inline-grid;
        place-items: center;
        width: 34px;
        height: 34px;
        padding: 0;
        border: 1px solid var(--rm-border);
        border-radius: 999px;
        background: var(--rm-surface);
        font-size: 0.95rem;
        line-height: 1;
        cursor: pointer;
        transition: border-color 0.15s ease, background 0.15s ease;
      }
      .theme-toggle:hover { border-color: var(--rm-accent); background: var(--rm-surface-hover); }
      .theme-toggle:focus-visible { outline: 2px solid var(--rm-accent); outline-offset: 2px; }
      .theme-toggle .icon-sun { display: none; }
      html[data-theme='dark'] .theme-toggle .icon-sun { display: block; }
      html[data-theme='dark'] .theme-toggle .icon-moon { display: none; }

      /* Enlace "Volver" dentro de la barra de cada herramienta. */
      .tool-back {
        text-decoration: none;
        color: var(--rm-muted);
        font-weight: 600;
        font-size: 0.9rem;
        margin-right: 0.75rem;
      }
      .tool-back:hover { color: var(--rm-accent); }

      .site-main {
        max-width: var(--rm-max);
        margin: 0 auto;
        padding: 1rem 1.5rem 3rem;
      }
      .site-footer {
        max-width: var(--rm-max);
        margin: 0 auto;
        padding: 1.5rem;
        color: var(--rm-muted);
        font-size: 0.8rem;
        border-top: 1px solid var(--rm-border);
      }
      h1.page-title { font-size: 1.6rem; margin: 0.5rem 0 0.25rem; }
      p.page-lead { color: var(--rm-muted); margin: 0 0 1.5rem; max-width: 60ch; }

      /* Aviso de versión nueva del PWA (RMR-TSK-0158): banner persistente
         hasta que el usuario recarga (el botón borra la caché del SW). */
      #sw-update-banner {
        position: fixed;
        left: 50%;
        bottom: 1rem;
        transform: translateX(-50%);
        z-index: 1000;
        display: flex;
        align-items: center;
        gap: 0.9rem;
        max-width: calc(100vw - 2rem);
        padding: 0.65rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--rm-border);
        background: var(--rm-surface);
        color: var(--rm-text);
        font-size: 0.9rem;
        box-shadow: 0 10px 30px rgba(17, 24, 39, 0.25);
      }
      #sw-update-banner button {
        border: 1px solid var(--rm-accent);
        background: var(--rm-accent);
        color: var(--rm-on-accent, #fff);
        border-radius: 8px;
        padding: 0.35rem 0.9rem;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
        white-space: nowrap;
      }
      #sw-update-banner button:hover:not(:disabled) { filter: brightness(1.08); }
      #sw-update-banner button:focus-visible { outline: 2px solid var(--rm-accent); outline-offset: 2px; }
      #sw-update-banner button:disabled { opacity: 0.7; cursor: wait; }
    </style>

    <!-- Define <auth-button> y aplica el guard de rutas protegidas. -->
    <script>
      import '../client/layout.js';
    </script>
  </body>
</html>
