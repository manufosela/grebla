rules_version = '2';

// Reglas de seguridad de GREBLA (modelo multi-leader: una instancia = una
// organización; ADR -OwN-T_4VB3Ut1Dbn-j8).
//
//   /admins/{uid}    Superadmin de la instancia (ve todo; da de alta líderes).
//   /viewers/{uid}   Viewers (solo lectura, tipo C-level). Alta solo por superadmin.
//   /leaders/{uid}   Líderes (gestionan sus personas). Alta solo por superadmin.
//   Datos a nivel raíz: /people, /areas, /config, /guilds, /dora, /journeys.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isViewer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/viewers/$(request.auth.uid));
    }
    function isLeader() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/leaders/$(request.auth.uid));
    }
    // MIEMBRO de la instancia: persona asociada a un manager/equipo. El espejo
    // /members/{uid} lo mantiene el trigger `syncMemberRegistry` (las personas
    // viven en /people con id propio, así que el uid no es consultable desde
    // una regla). RMR-TSK-0274.
    function isMember() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/members/$(request.auth.uid));
    }
    // Correo corporativo: permite participar en una retro por enlace aunque aún
    // no se esté asociado a ningún manager (no da acceso a nada más de GREBLA).
    function isOrgEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@tribbuapp[.]com');
    }
    // Quién puede leer/participar en una retro (RMR-TSK-0274): roles de la
    // instancia, miembros asociados a un manager (aunque su correo sea externo)
    // y cualquiera de tribbuapp.com con el enlace. Un gmail suelto, no.
    function canAccessRetro() {
      return isSuperAdmin() || isViewer() || isLeader() || isMember() || isOrgEmail();
    }

    // Espejo de miembros por uid: lo escribe SOLO el trigger (Admin SDK, que se
    // salta las reglas). Ningún cliente puede auto-registrarse aquí.
    match /members/{memberUid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Superadmins: legible por autenticados; escritura solo por un superadmin
    // existente (el primero se crea con el Admin SDK, que omite las reglas).
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Líderes de la instancia: legibles por autenticados (para los selectores de
    // compartir); alta/baja solo por superadmin.
    match /leaders/{uid} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Viewers de la instancia (solo lectura, tipo C-level): legibles por
    // autenticados (para la pestaña Usuarios); alta/baja solo por superadmin.
    // El viewer nunca escribe: ni aquí ni en ninguna otra colección.
    match /viewers/{uid} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Interpretación IA vigente por herramienta (lean/dora): la genera y sobrescribe
    // SOLO la Cloud Function interpretMetrics (Admin SDK, restringida a superadmin);
    // la leen todos los autenticados con acceso a la herramienta. El cliente nunca
    // escribe aquí (por eso write: false; el Admin SDK omite las reglas).
    match /interpretations/{tool} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Directorio de usuarios que han iniciado sesión (nombre, email, última
    // conexión). Cada usuario escribe SOLO su propio doc (registro de presencia);
    // la lista la leen superadmin y viewer (pestaña Usuarios) y el líder (para
    // ofrecer las cuentas "sin asignar" al vincular una persona). No otorga
    // acceso: el rol se decide en /admins, /viewers, /leaders.
    match /users/{uid} {
      allow read: if isSuperAdmin() || isViewer() || isLeader();
      // El propio usuario escribe su doc al iniciar sesión; un superadmin puede
      // corregir el nombre visible de cualquier cuenta (pestaña Usuarios).
      allow write: if (isSignedIn() && request.auth.uid == uid) || isSuperAdmin();
    }

    // Marea (RMR-PCS-0021): pulso afectivo semanal. Cada persona guarda un
    // registro por día en /pulse/{uid}/entries/{YYYY-MM-DD} y SOLO accede a lo
    // suyo — el registro individual es privado. El agregado anónimo del equipo lo
    // calcula una Cloud Function (Admin SDK, omite estas reglas). En la escritura
    // se exige que el campo uid coincida con el dueño (no se puede suplantar).
    match /pulse/{uid}/entries/{day} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.uid == uid;
    }

    // Agregados anónimos de Marea por semana (medias por dimensión: general, por
    // gremio y por label/squad, solo grupos con >=3). Los calcula y escribe SOLO
    // la Cloud Function aggregatePulse (Admin SDK, omite reglas); los lee toda la
    // tripulación autenticada (la vista Resultados). El cliente nunca escribe.
    match /pulseAggregates/{weekIso} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Secretos (token GitHub de DORA): nunca accesibles desde el cliente; solo
    // la Cloud Function vía Admin SDK (omite reglas).
    match /private/{document=**} {
      allow read, write: if false;
    }

    // Personas del equipo (tool Equipo + Role Mirror). Cada persona lleva
    // ownerLeaderUid (dueño) y sharedWith (uid→'view'|'edit'); el superadmin ve
    // todo. sharedWithUids es el espejo para consultas array-contains.
    match /people/{personId} {
      function isOwner() {
        return isSignedIn() && resource.data.ownerLeaderUid == request.auth.uid;
      }
      // Jugador VINCULADO (JG-1): la cuenta logada es la del titular de la
      // persona (el doc padre lleva uid == request.auth.uid). Mismo patrón de
      // get() del doc padre que la excepción del brujo; el guard 'uid' in
      // evita romper la regla en personas sin cuenta vinculada.
      function isLinkedPlayer() {
        return isSignedIn()
          && 'uid' in get(/databases/$(database)/documents/people/$(personId)).data
          && get(/databases/$(database)/documents/people/$(personId)).data.uid == request.auth.uid;
      }
      function sharedPerm(data) {
        return isSignedIn() && 'sharedWith' in data ? data.sharedWith[request.auth.uid] : null;
      }
      // La lectura (incl. la query por sharedWithUids) se respalda con el MISMO
      // campo que usa la consulta (el array), no con el mapa sharedWith; si no,
      // Firestore rechaza la query del líder (rules are not filters). El viewer
      // (solo lectura, tipo C-level) ve todo, igual que el superadmin. El usuario
      // vinculado (Person.uid == su uid) lee su propia ficha en solo lectura; el
      // guard 'uid' in resource.data evita romper la regla en personas sin campo.
      allow read: if isSuperAdmin() || isViewer() || isOwner()
        || ('sharedWithUids' in resource.data && request.auth.uid in resource.data.sharedWithUids)
        || (isSignedIn() && 'uid' in resource.data && resource.data.uid == request.auth.uid);
      // El líder crea sus personas; el superadmin puede crear una persona para
      // cualquier líder (asignar un usuario a un equipo desde el panel).
      allow create: if isSuperAdmin()
        || (isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid);
      // Un editor compartido edita datos pero NO transfiere la propiedad. El
      // ingeniero vinculado (Person.uid == su uid) SOLO puede declarar su objetivo
      // de carrera: la última rama restringe el cambio al único campo
      // `careerTargetLevelId` (hasOnly), sin poder tocar ningún otro dato de su ficha.
      allow update: if isSuperAdmin() || isOwner()
        || (sharedPerm(resource.data) == 'edit'
            && request.resource.data.ownerLeaderUid == resource.data.ownerLeaderUid)
        || (isSignedIn() && 'uid' in resource.data && resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['careerTargetLevelId']));
      allow delete: if isSuperAdmin() || isOwner();

      // Consultas al brujo (MC-22): el jugador vinculado (Person.uid ==
      // auth.uid) CREA preguntas de SU persona (siempre nacen 'pending') y
      // MARCA la respuesta como vista (solo status+seenAt, y solo a 'seen');
      // el resto de escrituras siguen las reglas del subárbol de abajo (líder
      // dueño/compartido-edit/superadmin), que también cubren la lectura.
      // ADITIVO al {document=**}: en Firestore las reglas de matches
      // solapados se OR-ean. OJO al path: el doc es
      // /people/{p}/career/wizard/questions/{qId} — el del diseño original
      // (/career/questions/{qId}) tiene 5 segmentos (colección, no documento)
      // y la regla jamás aplicaría a un doc real.
      match /career/wizard/questions/{questionId} {
        allow create: if isSignedIn()
          && 'uid' in get(/databases/$(database)/documents/people/$(personId)).data
          && get(/databases/$(database)/documents/people/$(personId)).data.uid == request.auth.uid
          && request.resource.data.status == 'pending';
        allow update: if isSignedIn()
          && 'uid' in get(/databases/$(database)/documents/people/$(personId)).data
          && get(/databases/$(database)/documents/people/$(personId)).data.uid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'seenAt'])
          && request.resource.data.status == 'seen';
      }

      // EL INGENIERO JUEGA (JG-1, RMR-TSK-0139): el jugador vinculado escribe
      // (crea/actualiza) EXACTAMENTE tres documentos de su plan de desarrollo,
      // que es SUYO:
      //  - career/journey: ruta planificada, ciudades visitadas/actual,
      //    evidencias e isla actual (jugar el mapa con su cuenta).
      //  - career/playtime: su cronómetro de tiempo de juego (el tracker
      //    vuelca con increment sobre su propia persona).
      //  - career/achievements: sus logros con fecha. Que pueda escribirlo es
      //    COSMÉTICO: la capa antifraude real son los tribbu-coins firmados
      //    por la Cloud Function (/coins, emisor único, escritura de cliente
      //    prohibida) — inflarse la ficha no acuña ninguna moneda.
      // ADITIVO al {document=**} de abajo (en Firestore las reglas de matches
      // solapados se OR-ean): líder dueño / compartido-edit / superadmin
      // siguen escribiendo por esa vía. El resto del subárbol (nivel,
      // valoraciones, lecturas, notas, Role Mirror) sigue siendo del líder:
      // el vinculado NO gana escritura fuera de estos tres docs. Sin delete:
      // el plan se corrige, no se borra.
      match /career/journey {
        allow create, update: if isLinkedPlayer();
      }
      match /career/playtime {
        allow create, update: if isLinkedPlayer();
      }
      match /career/achievements {
        allow create, update: if isLinkedPlayer();
      }
      //  - career/logbook: su bitácora (histórico solo-añadir de certificados
      //    y rutas). Que el jugador la escriba es el punto de JG-23.
      match /career/logbook {
        allow create, update: if isLinkedPlayer();
      }

      // EL INGENIERO AFINA SU ROLE MIRROR (RMR-TSK-0224): el rol se fija de forma
      // CONJUNTA — el líder propone (autorrelleno) y el ingeniero termina de afinar
      // su propio cuestionario al loguearse. El jugador vinculado crea/actualiza su
      // resumen y sus sesiones de Role Mirror. ADITIVO al {document=**} de abajo (las
      // reglas de matches solapados se OR-ean): el líder dueño/compartido-edit/
      // superadmin siguen escribiendo por esa vía. Sin delete: el histórico no se borra.
      match /rolemirror/{document=**} {
        allow create, update: if isLinkedPlayer();
      }

      // Subárbol de la persona (lecturas por dimensión, conversaciones, notas,
      // resumen/sesiones de Role Mirror): hereda el acceso de la persona.
      match /{document=**} {
        function person() {
          return get(/databases/$(database)/documents/people/$(personId)).data;
        }
        function canView() {
          return isSuperAdmin() || isViewer()
            || (isSignedIn()
                && (person().ownerLeaderUid == request.auth.uid
                    || ('uid' in person() && person().uid == request.auth.uid)
                    || ('sharedWith' in person() && person().sharedWith[request.auth.uid] in ['view', 'edit'])));
        }
        function canEdit() {
          return isSuperAdmin()
            || (isSignedIn()
                && (person().ownerLeaderUid == request.auth.uid
                    || ('sharedWith' in person() && person().sharedWith[request.auth.uid] == 'edit')));
        }
        allow read: if canView();
        allow write: if canEdit();
      }
    }

    // Áreas de conocimiento: catálogo con ámbito, mismo modelo que guilds/labels.
    // Globales (sin ownerLeaderUid, los gestiona el superadmin) y personales
    // (ownerLeaderUid = líder). Cada líder crea/borra las suyas; el superadmin
    // gestiona globales y promueve (quita owner).
    match /areas/{areaId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin()
        || (isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow update: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid
            && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow delete: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid);
    }

    // Catálogo de gremios (tecnologías/stack) con ámbito: globales (sin
    // ownerLeaderUid, los gestiona el superadmin) y personales (ownerLeaderUid =
    // líder). Cada líder crea/borra los suyos; el superadmin gestiona globales y
    // promueve (quita owner).
    match /guilds/{guildId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin()
        || (isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow update: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid
            && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow delete: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid);
    }

    // Catálogo de labels: mismo modelo de ámbito que guilds.
    // Squads: catálogo de la ORGANIZACIÓN (RMR-TSK-0275). Lo lee cualquiera con
    // acceso (para pintar a qué squad pertenece cada persona) y lo gestiona el
    // superadmin; un manager NO crea squads porque son transversales a managers.
    match /squads/{squadId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /labels/{labelId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin()
        || (isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow update: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid
            && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow delete: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid);
    }

    // O2O (One-to-Ones) — plantillas de catálogo: la guía de temas y el
    // formulario previo. Lectura a cualquier firmado; escritura a líder o
    // superadmin. Las SESIONES privadas del líder (transcripción, notas, resumen)
    // NO cuelgan de aquí ni de la persona: irán bajo /leaders/{uid}/o2o en fases
    // siguientes, invisibles para el ingeniero.
    match /o2oGuides/{guideId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isLeader();
    }
    match /o2oForms/{formId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isLeader();
    }

    // O2O — SESIONES privadas del líder: transcripción, notas, respuestas de la
    // guía y resumen. Solo el propio líder dueño (o el superadmin) leen/escriben.
    // El ingeniero NO tiene ruta aquí; lo que se le comparte se sirve por Cloud
    // Function (proyección filtrada), nunca leyendo esta colección.
    match /leaders/{leaderUid}/o2o/{sessionId} {
      allow read, write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == leaderUid);
    }

    // O2O — PERIODOS del líder (campañas con su guía/formulario embebidos). Solo
    // el propio líder dueño (o el superadmin). Mismo criterio que las sesiones.
    match /leaders/{leaderUid}/o2oPeriods/{periodId} {
      allow read, write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == leaderUid);
    }

    // Configuración: /config/org (Role Mirror, superadmin); /config/settings
    // (ajustes de la tool Equipo, líderes).
    match /config/org {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    match /config/settings {
      allow read: if isSignedIn();
      allow write: if isLeader() || isSuperAdmin();
    }
    // Versión desplegada de la app (para detectar clientes con caché vieja). La
    // lee cualquiera (incluida la pantalla de login, sin sesión); solo la escribe
    // el script de deploy vía Admin SDK (nunca desde el cliente).
    match /config/appVersion {
      allow read: if true;
      allow write: if false;
    }

    // DORA: config de entrega owner-scoped (mismo modelo que /guilds). Cada repo
    // lleva ownerLeaderUid (el líder que lo añadió). Un mismo repo puede coincidir
    // entre líderes (docs distintos). Lectura: autenticados (la lista del líder se
    // filtra por owner en el cliente; el superadmin ve todos). El líder crea/edita/
    // borra los SUYOS; el superadmin, todos. La Cloud Function refreshDora usa el
    // Admin SDK (omite reglas), así que el cálculo de métricas no depende de esto.
    match /dora/{repoId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin()
        || (isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow update: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid
            && request.resource.data.ownerLeaderUid == resource.data.ownerLeaderUid);
      allow delete: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid);

      // Eventos de despliegue real de un repo (registro manual; base de la
      // frecuencia real, y luego de Lead Time/CFR/MTTR). Los gestiona el líder
      // dueño del repo (comprobando el ownerLeaderUid del doc padre) o el superadmin.
      match /deployments/{deployId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSuperAdmin()
          || (isLeader()
              && 'ownerLeaderUid' in get(/databases/$(database)/documents/dora/$(repoId)).data
              && get(/databases/$(database)/documents/dora/$(repoId)).data.ownerLeaderUid == request.auth.uid);
      }

      // Incidentes en producción de un repo (registro manual; base del MTTR, D4).
      // Mismos permisos que /deployments: los gestiona el líder dueño del repo
      // (comprobando el ownerLeaderUid del doc padre) o el superadmin.
      match /incidents/{incidentId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSuperAdmin()
          || (isLeader()
              && 'ownerLeaderUid' in get(/databases/$(database)/documents/dora/$(repoId)).data
              && get(/databases/$(database)/documents/dora/$(repoId)).data.ownerLeaderUid == request.auth.uid);
      }
    }

    // LEAN / Flujo: equipos de Linear monitorizados (mismo modelo owner-scoped que
    // /dora). Las métricas las calcula la Cloud Function refreshLean (Admin SDK).
    match /leanTeams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSuperAdmin()
        || (isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid);
      allow update: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid
            && request.resource.data.ownerLeaderUid == resource.data.ownerLeaderUid);
      allow delete: if isSuperAdmin()
        || (isLeader() && resource.data.ownerLeaderUid == request.auth.uid);
    }

    // Mapa de Carrera: el journey de cada persona, solo suyo.
    match /journeys/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    // Carpools de formación (CP-1): grupos con nombre que recorren juntos una
    // ruta de paradas del archipiélago. Colección raíz de la instancia.
    //  - Lectura: autenticados (el tablón lo ve todo el mundo logueado).
    //  - Crear: cualquier usuario autenticado de la instancia, y el doc debe
    //    declararle como creador (createdBy.uid == auth.uid): nadie firma
    //    carpools en nombre de otro. Desde JG-1 el jugador vinculado también
    //    crea; los viewers no juegan (la UI no les ofrece crear), pero un
    //    carpool firmado como uno mismo no rompe ninguna garantía — la firma
    //    es la barrera, no el rol.
    //  - Editar/borrar: el creador o el superadmin… MÁS la rama de UNIRSE/
    //    SALIR: cualquier autenticado puede actualizar SOLO
    //    members/memberIds/status (hasOnly) — antes solo líderes; desde JG-1
    //    el ingeniero se une/sale con su cuenta. La validación fina de la
    //    unión (hay plaza, está 'open', no estás ya dentro) es de CLIENTE en
    //    esta v1 pragmática — un usuario malicioso podría saltársela, pero no
    //    puede tocar nombre/ruta/aforo ni firmar como otro.
    match /carpools/{carpoolId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy.uid == request.auth.uid;
      allow update: if isSuperAdmin()
        || (isSignedIn() && resource.data.createdBy.uid == request.auth.uid)
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['members', 'memberIds', 'status']));
      allow delete: if isSuperAdmin()
        || (isSignedIn() && resource.data.createdBy.uid == request.auth.uid);
    }

    // TRIBBU-COINS (CP-2): libro mayor firmado y verificable. /coins/meta
    // (contador seq + cabeza de la cadena), /coins/ledger/entries/{entryId}
    // (apuntes hash-encadenados y firmados con KMS) y
    // /coins/balances/people/{personId} (saldos materializados). SOLO LECTURA
    // para cualquier autenticado (todos pueden auditar el ledger); escribe
    // únicamente la Cloud Function emisora vía Admin SDK (omite reglas).
    // Cualquier escritura de cliente rompería la garantía del emisor único.
    match /coins/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Mapa de Carrera (la isla): documento único /careerMap/island con las
    // comarcas, ciudades y puerto de inicio. Lo leen los autenticados (el tool);
    // solo lo edita el superadmin desde el panel /admin.
    match /careerMap/{doc} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Referencias de aprendizaje aportadas por la TRIPULACIÓN (RMR-TSK-0255): un
    // ingeniero añade a una casa recursos que le ayudaron a certificarse; los ven
    // todos, con el nombre de quien los aportó. Viven aquí (no en /careerMap, que
    // es write-solo-superadmin). Cada uno crea firmando con su propio uid; borra
    // sus aportes (o cualquiera un manager/superadmin, para moderar spam). Sin
    // update: una referencia se borra y se vuelve a crear, no se edita.
    match /cityReferences/{refId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.url is string
        && request.resource.data.title is string
        && request.resource.data.cityKey is string;
      allow delete: if isSignedIn()
        && (resource.data.authorUid == request.auth.uid || isSuperAdmin() || isLeader());
    }

    // Rutas de ROL y NIVEL del Modo Reto (JG-14): un doc por hito
    // /careerRoutes/{disciplina}--{hito} con {discipline, levelKey, name,
    // description, stops, active}. Las leen los autenticados (el selector de
    // retos); solo las edita el superadmin (editor de juego en /admin).
    match /careerRoutes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Framework de Carrera (catálogo global): documento único
    // /careerFramework/engineering con tracks, niveles, disciplinas y
    // dimensiones. Lo leen los autenticados; solo lo edita el superadmin.
    match /careerFramework/{doc} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // MOTIVADORES — juegos de cartas (Moving & Affective Motivators).
    // Rondas globales: las crea/edita el superadmin; las lee cualquier autenticado.
    match /motivatorRounds/{roundId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // Sesiones PRIVADAS del jugador. Id determinista {roundId}__{usuarioId}; cada
    // doc lleva su `uid` dueño. La lee el dueño o el superadmin (nunca otros
    // jugadores). La escribe solo el dueño y solo con la ronda ABIERTA: se hace
    // get() de la ronda y se comprueba que request.time cae en [startAt, endAt]
    // (fechas guardadas como Timestamp). La barrera es la firma (uid == auth.uid):
    // nadie escribe la sesión de otro. Los agregados públicos los calcula la Cloud
    // Function onMotivatorSessionWritten con Admin SDK (omite estas reglas).
    match /motivatorSessions/{sessionId} {
      function roundRef() {
        return get(/databases/$(database)/documents/motivatorRounds/$(request.resource.data.roundId)).data;
      }
      function roundOpen() {
        return roundRef().active == true
          && request.time >= roundRef().startAt
          && request.time <= roundRef().endAt;
      }
      allow read: if isSuperAdmin()
        || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && roundOpen();
      allow delete: if isSuperAdmin();
    }

    // Agregados públicos por juego (posición media, top-3, evolución…). Los lee
    // cualquier autenticado; solo los escribe la Cloud Function (Admin SDK). Nunca
    // desde el cliente: rompería la garantía de que no se filtran datos individuales.
    match /motivatorAggregates/{game} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // RETROS (RMR-PCS-0022): retrospectivas de equipo. La retro la crea/gestiona su
    // líder dueño (ownerLeaderUid); la lee cualquier autenticado (colaborativa). Las
    // notas se muestran ANÓNIMAS pero guardan authorUid: cada uno edita/borra las
    // suyas y cualquiera vota (solo toca el array `voters`, idempotente). Las
    // acciones (/retroActions) son de equipo y persisten entre retros: las crea el
    // líder y su owner (o el líder) marca hecha/pendiente.
    match /retros/{retroId} {
      allow read: if canAccessRetro();
      allow create: if isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid;
      allow update, delete: if isSuperAdmin()
        || (isSignedIn() && resource.data.ownerLeaderUid == request.auth.uid);

      match /notes/{noteId} {
        // Votar solo puede cambiar el array `voters` (nada más de la nota).
        function onlyVotersChanged() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['voters']);
        }
        // Agrupar tarjetas que dicen lo mismo (RMR-TSK-0281): lo hace quien
        // facilita la retro (su dueño) o un superadmin, y SOLO puede tocar
        // `groupId` — no el texto ni la autoría de la nota de otra persona.
        function onlyGroupChanged() {
          return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['groupId']);
        }
        function isRetroOwner() {
          return isSignedIn()
            && get(/databases/$(database)/documents/retros/$(retroId)).data.ownerLeaderUid == request.auth.uid;
        }
        allow read: if canAccessRetro();
        allow create: if canAccessRetro() && request.resource.data.authorUid == request.auth.uid;
        // El autor edita su nota; cualquiera con acceso a la retro vota (solo `voters`).
        allow update: if (canAccessRetro()
            && (resource.data.authorUid == request.auth.uid || onlyVotersChanged()))
          || ((isRetroOwner() || isSuperAdmin()) && onlyGroupChanged());
        // Borra el autor de la nota o el líder dueño de la retro (o superadmin).
        allow delete: if isSuperAdmin()
          || (isSignedIn() && resource.data.authorUid == request.auth.uid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/retros/$(retroId)).data.ownerLeaderUid == request.auth.uid);
      }
    }

    // Acciones de retro (nivel equipo, persisten entre retros hasta cerrarse).
    match /retroActions/{actionId} {
      // El owner (o el líder) solo cambia el estado (status + doneAt).
      function onlyStatusChanged() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'doneAt']);
      }
      allow read: if canAccessRetro();
      allow create: if isLeader() && request.resource.data.ownerLeaderUid == request.auth.uid;
      allow update: if isSuperAdmin()
        || (isSignedIn() && resource.data.ownerLeaderUid == request.auth.uid)
        || (canAccessRetro() && request.auth.uid in resource.data.owners && onlyStatusChanged());
      allow delete: if isSuperAdmin()
        || (isSignedIn() && resource.data.ownerLeaderUid == request.auth.uid);
    }

    // Resto: denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
