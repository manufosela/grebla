rules_version = '2';

// Reglas de seguridad de GREBLA.
//
// Modelo:
//   /users/{uid}                      Solo el propio uid (admin puede leer).
//   /users/{uid}/sessions/{sessionId} Solo el propio uid (admin puede leer).
//   /admins/{uid}                     Lectura para autenticados; escritura SOLO para admins.
//                                     El alta de administradores se hace server-side
//                                     (Admin SDK / seed / Cloud Function grantAdmin):
//                                     NO existe ningún bootstrap self-service desde el cliente.
//   /config/org                       Lectura para autenticados; escritura SOLO para admins.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Plataforma multi-tenant: /admins son los super-admins de plataforma.
    function isSuperAdmin() {
      return isAdmin();
    }
    function isTenantMember(tenantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }
    function tenantRole(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role;
    }
    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) && tenantRole(tenantId) == 'admin';
    }

    // Datos del usuario: solo su dueño escribe; dueño o admin leen.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid);
      // El dueño borra su perfil; un admin puede borrar el de cualquier usuario
      // (gestión desde el panel admin). La cuenta de Auth se gestiona aparte.
      allow delete: if isOwner(uid) || isAdmin();

      match /sessions/{sessionId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid);
        // El dueño borra sus mediciones; un admin puede borrar las de cualquier
        // usuario (gestión de datos desde el panel admin). No crea ni edita.
        allow delete: if isOwner(uid) || isAdmin();
      }
    }

    // Administradores: legible por autenticados; escritura SOLO por un admin
    // existente. El primer admin se crea fuera de las reglas con el Admin SDK,
    // que las omite. No hay forma de auto-concederse admin desde el cliente.
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Configuración: org legible por autenticados, escribible por admins.
    match /config/org {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Catálogo GLOBAL de roles de equipo (GREBLA): común a toda la organización.
    // Cualquier autenticado lo lee; solo un admin puede crear/borrar roles.
    match /teamRoles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // DORA — configuración GLOBAL de repos de la organización. Lectura para
    // autenticados (las métricas son de equipo, compartibles); escritura solo
    // admin. El token de GitHub NO vive aquí: es un secreto de la Cloud Function.
    match /doraRepos/{repoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // GREBLA — herramienta de seguimiento de equipo. Todo el árbol de un owner
    // (personas, lecturas por dimensión, conversaciones, support notes R5,
    // áreas y config) es accesible SOLO por su dueño. La frontera R5/R6 (support
    // notes y agregado vs individual) se garantiza en servicios/export; si en el
    // futuro hay roles, ya es estructural y se traduce a reglas por colección.
    match /owners/{ownerId}/{document=**} {
      allow read, write: if isOwner(ownerId);
    }

    // ── SaaS multi-tenant ──────────────────────────────────────────────────
    // Mapa host → tenantId: legible por todos (se consulta ANTES del login para
    // resolver el tenant por dominio); escritura solo super-admin de plataforma.
    match /tenantDomains/{host} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Árbol de cada tenant. La plataforma crea/gestiona el tenant; sus admins
    // gestionan miembros y catálogos; cada líder gestiona SU propio subárbol.
    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId) || isSuperAdmin();
      allow write: if isSuperAdmin();

      match /members/{uid} {
        allow read: if isTenantMember(tenantId) || isSuperAdmin();
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }

      // Secretos (p. ej. token GitHub de DORA): NUNCA accesibles desde el cliente;
      // solo la Cloud Function vía Admin SDK (omite reglas).
      match /private/{document=**} {
        allow read, write: if false;
      }

      // Datos de las herramientas migradas bajo tenant (la migración real de los
      // tools actuales es 1b/1c; aquí ya quedan las reglas listas).
      match /leaders/{leaderUid}/{document=**} {
        allow read, write: if isTenantMember(tenantId) && request.auth.uid == leaderUid;
      }
      match /teamRoles/{roleId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }
      match /dora/{document=**} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }
    }

    // Resto: denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
