rules_version = '2';

// Reglas de seguridad de GREBLA.
//
// Modelo:
//   /admins/{uid}                     Lectura para autenticados; escritura SOLO para admins.
//                                     El alta de administradores se hace server-side
//                                     (Admin SDK / seed / Cloud Function grantAdmin):
//                                     NO existe ningún bootstrap self-service desde el cliente.
//   Los datos de Role Mirror (config, perfil y sesiones) viven por tenant en
//   /tenants/{tid}/{config,rolemirror}/... (ver más abajo). No hay datos globales /users.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Plataforma multi-tenant: /admins son los super-admins de plataforma.
    function isSuperAdmin() {
      return isAdmin();
    }
    function isTenantMember(tenantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid));
    }
    function tenantRole(tenantId) {
      return get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(request.auth.uid)).data.role;
    }
    function isTenantAdmin(tenantId) {
      return isTenantMember(tenantId) && tenantRole(tenantId) == 'admin';
    }

    // Administradores: legible por autenticados; escritura SOLO por un admin
    // existente. El primer admin se crea fuera de las reglas con el Admin SDK,
    // que las omite. No hay forma de auto-concederse admin desde el cliente.
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Multi-leader (ADR -OwN-T_4VB3Ut1Dbn-j8): líderes de la instancia, a nivel
    // raíz (una instancia = una organización). Los da de alta un superadmin.
    // Legibles por cualquier autenticado (para los selectores de compartir).
    match /leaders/{uid} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    // (Las colecciones globales /teamRoles, /doraRepos y /owners se han retirado:
    //  ahora viven por tenant — ver /tenants más abajo.)

    // ── SaaS multi-tenant ──────────────────────────────────────────────────
    // Mapa host → tenantId: legible por todos (se consulta ANTES del login para
    // resolver el tenant por dominio); escritura solo super-admin de plataforma.
    match /tenantDomains/{host} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Árbol de cada tenant. La plataforma crea/gestiona el tenant; sus admins
    // gestionan miembros y catálogos; cada líder gestiona SU propio subárbol.
    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId) || isSuperAdmin();
      allow write: if isSuperAdmin();

      match /members/{uid} {
        allow read: if isTenantMember(tenantId) || isSuperAdmin();
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }

      // Secretos (p. ej. token GitHub de DORA): NUNCA accesibles desde el cliente;
      // solo la Cloud Function vía Admin SDK (omite reglas).
      match /private/{document=**} {
        allow read, write: if false;
      }

      // Personas del equipo (tool Equipo + Role Mirror), a nivel de tenant para
      // poder compartirlas/transferirlas entre líderes (Fase 3). Cada persona
      // lleva `ownerLeaderUid` (dueño) y `sharedWith` (mapa uid→'view'|'edit'):
      // el dueño y el admin acceden siempre; un líder con permiso 'view' lee y
      // con 'edit' también escribe. El espejo `sharedWithUids` solo es para query.
      match /people/{personId} {
        function isPersonOwner() {
          return isTenantMember(tenantId)
            && resource.data.ownerLeaderUid == request.auth.uid;
        }
        // Permiso de compartición del usuario actual sobre `data` (null si ninguno).
        function sharedPerm(data) {
          return isTenantMember(tenantId) && 'sharedWith' in data
            ? data.sharedWith[request.auth.uid]
            : null;
        }
        allow read: if isPersonOwner() || isTenantAdmin(tenantId) || isSuperAdmin()
          || sharedPerm(resource.data) in ['view', 'edit'];
        allow create: if isTenantMember(tenantId)
          && request.resource.data.ownerLeaderUid == request.auth.uid;
        // Un editor compartido puede editar datos, pero NO transferir la propiedad
        // (cambiar ownerLeaderUid es transferencia: dueño/admin, fase 3c).
        allow update: if isTenantAdmin(tenantId) || isSuperAdmin() || isPersonOwner()
          || (sharedPerm(resource.data) == 'edit'
              && request.resource.data.ownerLeaderUid == resource.data.ownerLeaderUid);
        allow delete: if isPersonOwner() || isTenantAdmin(tenantId) || isSuperAdmin();

        // Subárbol de la persona (lecturas por dimensión, conversaciones, notas,
        // resumen/sesiones de Role Mirror): hereda el acceso de la persona.
        match /{document=**} {
          function person() {
            return get(/databases/$(database)/documents/tenants/$(tenantId)/people/$(personId)).data;
          }
          function canView() {
            return isTenantMember(tenantId)
              && (person().ownerLeaderUid == request.auth.uid
                  || ('sharedWith' in person() && person().sharedWith[request.auth.uid] in ['view', 'edit']));
          }
          function canEdit() {
            return isTenantMember(tenantId)
              && (person().ownerLeaderUid == request.auth.uid
                  || ('sharedWith' in person() && person().sharedWith[request.auth.uid] == 'edit'));
          }
          allow read: if isTenantAdmin(tenantId) || isSuperAdmin() || canView();
          allow write: if isTenantAdmin(tenantId) || isSuperAdmin() || canEdit();
        }
      }

      // Áreas de conocimiento: catálogo del tenant compartido por sus líderes.
      match /areas/{areaId} {
        allow read, write: if isTenantMember(tenantId);
      }

      // Ajustes de la tool Equipo (features, etc.) del tenant.
      match /config/settings {
        allow read, write: if isTenantMember(tenantId);
      }

      match /teamRoles/{roleId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }
      match /dora/{document=**} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // Configuración de Role Mirror (fase/pesos) del tenant: la leen los
      // miembros; la escribe el admin del tenant (o el super-admin de plataforma).
      match /config/org {
        allow read: if isTenantMember(tenantId) || isSuperAdmin();
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }

      // Role Mirror vive bajo la persona, a nivel de tenant
      // (/tenants/{tid}/people/{personId}/rolemirror/...), cubierto por la regla
      // del subárbol de /people/{personId} de arriba.

      // Mapa de Carrera: el journey de cada ingeniero, solo suyo.
      match /journeys/{uid} {
        allow read, write: if isTenantMember(tenantId) && request.auth.uid == uid;
      }
    }

    // Índice inverso usuario→tenants (para la landing "mis organizaciones").
    // Lo lee solo el dueño; lo mantiene quien asigna members (tenant-admin del
    // tid o super-admin de plataforma).
    match /userTenants/{uid}/tenants/{tid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isTenantAdmin(tid) || isSuperAdmin();
    }

    // Resto: denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
